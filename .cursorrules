## 📐 CODING STANDARDS (follow exactly)

### tRPC Router Pattern
```typescript
// server/routers/example.ts
import { z } from 'zod'
import { router, protectedProcedure } from '../_core/trpc'
import { requireActiveCompanyId } from '../_core/tenant'
import { requireWorkspaceMembership } from '../_core/membership'

export const exampleRouter = router({
  list: protectedProcedure
    .input(z.object({ /* ... */ }))
    .query(async ({ ctx, input }) => {
      const companyId = requireActiveCompanyId(ctx)
      // ALWAYS filter by companyId — never skip this
      const results = await db.select()
        .from(table)
        .where(eq(table.companyId, companyId))
      return results
    }),

  create: protectedProcedure
    .input(z.object({ /* ... */ }))
    .mutation(async ({ ctx, input }) => {
      const { companyId, userId } = await requireWorkspaceMembership(ctx)
      // Insert with companyId always
      const [result] = await db.insert(table).values({
        ...input,
        companyId,
        createdBy: userId,
      })
      // Audit log every mutation
      await db.insert(auditLogs).values({
        companyId, userId,
        action: 'create', resource: 'example', resourceId: String(result.insertId),
      })
      return result
    }),
})
```

### Drizzle Query Pattern
```typescript
// Always use repository functions, never raw Drizzle in routers
// server/repositories/example.repository.ts
import { db } from '../db'
import { eq, and, desc } from 'drizzle-orm'
import { exampleTable } from '../../drizzle/schema'

export async function findByCompany(companyId: number) {
  return db.select()
    .from(exampleTable)
    .where(eq(exampleTable.companyId, companyId))
    .orderBy(desc(exampleTable.createdAt))
}
```

### Frontend Component Pattern
```typescript
// Use TanStack Query for all server state
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'
import { trpc } from '../lib/trpc'  // or equivalent tRPC client

function ExamplePage() {
  const { data, isLoading } = trpc.example.list.useQuery()
  const qc = useQueryClient()
  
  const create = trpc.example.create.useMutation({
    onSuccess: () => qc.invalidateQueries({ queryKey: ['example'] })
  })
  
  if (isLoading) return <LoadingSpinner />
  // ...
}
```

### Migration Pattern
```typescript
// Always add a new numbered migration file
// drizzle/00XX_descriptive_name.sql
// Never modify existing migration files
// Run: pnpm db:migrate to apply
```

---

## 🔐 SECURITY RULES (non-negotiable)

1. **Every tRPC procedure** must call `requireActiveCompanyId(ctx)` or `requireWorkspaceMembership(ctx)`
2. **Every mutation** on an existing row must verify `row.companyId === ctx.companyId` before updating
3. **Every S3 URL generation** must validate ownership of the owning row first (see docs/ARCHITECTURE.md)
4. **Never** use `companyId ?? 1` or numeric fallbacks — throw `TRPCError({ code: 'UNAUTHORIZED' })` instead
5. **All file uploads** must: validate MIME type whitelist, enforce size limit (10MB default), partition S3 key by `companyId`
6. **Audit log** every create / update / delete / status change
7. **Rate limit** all public-facing routes (existing middleware in `server/_core/security.ts`)

---

## 🌍 OMAN-SPECIFIC BUSINESS RULES

Always apply these when building financial or HR features:

```typescript
const OMAN_CONSTANTS = {
  // Tax
  VAT_RATE: 0.05,                    // 5% VAT (introduced 2021)
  WITHHOLDING_TAX: 0.10,             // 10% on dividends / specific services
  
  // Payroll — PASI (Public Authority for Social Insurance)
  PASI_EMPLOYEE_CONTRIBUTION: 0.065, // 6.5% of basic salary (Omani nationals only)
  PASI_EMPLOYER_CONTRIBUTION: 0.105, // 10.5% of basic salary (Omani nationals only)
  PASI_MAX_INSURABLE_SALARY: 1500,   // OMR — salary cap for PASI calc
  
  // Labour law
  ANNUAL_LEAVE_DAYS: 30,             // minimum annual leave (Labour Law)
  SICK_LEAVE_DAYS: 10,               // paid sick leave per year
  MATERNITY_LEAVE_DAYS: 50,          // 50 calendar days
  NOTICE_PERIOD_DAYS: 30,            // standard (varies by contract)
  PROBATION_MAX_MONTHS: 3,           // max 3 months probation
  
  // Working hours
  NORMAL_HOURS_PER_DAY: 8,
  MAX_HOURS_PER_WEEK: 48,
  RAMADAN_HOURS_REDUCTION: 2,        // 2 hours less per day during Ramadan
  
  // Currency
  CURRENCY: 'OMR',
  CURRENCY_DECIMALS: 3,              // OMR uses 3 decimal places (baisa)
  
  // WPS (Wage Protection System)
  WPS_SUBMISSION_DEADLINE_DAYS: 10,  // must pay within 10 days of due date
}
```

