│   ├── contexts/       ← React contexts
│   ├── lib/            ← Utilities
│   ├── locales/        ← i18n translation files
│   └── App.tsx         ← Routes (wouter)
├── server/
│   ├── _core/          ← Auth, tenant, tRPC setup, LLM, storage
│   ├── routers/        ← 53 tRPC routers (one per domain)
│   └── *.ts            ← Domain services and test files
├── shared/             ← Shared types, RBAC, attendance logic, nav config
├── drizzle/
│   ├── schema.ts       ← 151 table definitions (4,194 lines)
│   └── *.sql           ← 57 migration files
└── docs/               ← Architecture decisions, specs, assessments
```

