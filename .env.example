# ─── Required for local / production ─────────────────────────────────────────
# MySQL (Drizzle). Example: mysql://user:pass@127.0.0.1:3306/smartpro
DATABASE_URL=

# Session JWT signing — production requires at least 16 characters
JWT_SECRET=

# TOTP (2FA): encrypts stored authenticator secrets at rest (AES-256-GCM). Min 32 characters; required when 2FA is enabled.
# TWO_FACTOR_ENCRYPTION_KEY=

# OAuth / app identity (must match Manus / your IdP app registration)
# If users see "email already registered with another sign-in method" on the IdP (e.g. api.manus.im),
# they must sign in with the same provider (Microsoft vs Google vs email) they used first — that rule is enforced by the IdP, not this app.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ─── Optional ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Database connection pool tuning (mysql2). Defaults shown.
# DB_POOL_SIZE=10
# DB_QUEUE_LIMIT=50
# DB_IDLE_TIMEOUT_MS=60000

# Comma-separated list of allowed Origins for CSRF validation on /api/trpc POST requests.
# Defaults to the request Host header (same-origin). Set this in production if your
# frontend is served from a different domain than the API.
# ALLOWED_ORIGINS=https://app.smartpro.om,https://www.smartpro.om

# Buyer Portal foundation (API + /buyer UI scaffold). Set both to "true" for local testing.
# BUYER_PORTAL_ENABLED=true
# VITE_BUYER_PORTAL_ENABLED=true

# Access v2 shadow mode: log when `input.companyId` !== legacy implicit workspace (first membership). No enforcement.
# ACCESS_V2_SHADOW_COMPANY=true

# Public site origin for absolute links in emails and survey admin (HTTPS in production).
# If unset, survey admin can still infer the base URL from the incoming browser request when the UI and API share the same host.
# PUBLIC_APP_URL=https://app.example.com
# Same purpose as PUBLIC_APP_URL; used for payment success/cancel redirects if set (either is accepted).
# APP_PUBLIC_URL=https://portal.thesmartpro.io

# ─── Client invoicing: Thawani + Stripe (required in production — see validateProductionEnvironment) ─
# THAWANI_SECRET_KEY=
# THAWANI_PUBLISHABLE_KEY=
# THAWANI_WEBHOOK_SECRET=
# Use Thawani production API (checkout.thawani.om). Omit or set false in dev to use UAT (uatcheckout.thawani.om).
# THAWANI_SANDBOX=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Developers → Webhooks → endpoint URL: https://<host>/api/webhooks/stripe
# Thawani dashboard webhook URL: https://<host>/api/webhooks/thawani

# First super-user openId from IdP (used by some bootstrap flows)
OWNER_OPEN_ID=

# Storage proxy (Forge / Manus built-in storage) — required for uploads if using storagePut
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Google Docs / Drive — required for HR “Generate contract” PDF flow (promoter assignments, etc.)
# Paste the full JSON of a service account that has Drive API + Google Docs API enabled, and share templates with its client_email.
# Example: GOOGLE_DOCS_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'
GOOGLE_DOCS_SERVICE_ACCOUNT_JSON=

# Google Doc template ID for the bilingual promoter assignment contract.
# Override the built-in default when deploying your own template copy.
# PROMOTER_TEMPLATE_GOOGLE_DOC_ID=

# Shared Drive (Team Drive) ID where temporary doc copies are created during PDF generation.
# Only needed if NOT using impersonation (GOOGLE_DOCS_IMPERSONATE_EMAIL).
# Create a Shared Drive in Google Drive, add the service account email as a Content Manager, and paste the drive ID here.
GOOGLE_DOCS_SHARED_DRIVE_ID=

# Google Workspace user email for the service account to impersonate via domain-wide delegation.
# The service account will act as this user, using their Drive storage for temporary file copies.
# Requires: Google Workspace Admin → Security → API controls → Domain-wide delegation →
#   add the service account client_id with scopes: https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/documents
GOOGLE_DOCS_IMPERSONATE_EMAIL=

# Optional: Sentry for server-side errors (Node). Set DSN in production secrets; never commit real values.
# SENTRY_SEND_DEFAULT_PII=true sends default PII (e.g. client IP) per Sentry settings.
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_SEND_DEFAULT_PII=false
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional: map widget on client (see client/src/components/Map.tsx)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# Optional: WhatsApp Cloud API — auto-send Arabic utility templates (Meta-approved).
# SANAD intel: after “Generate invite”, sends WHATSAPP_TEMPLATE_SANAD_INVITE_AR to the centre contact (body {{1}} name, {{2}} full invite URL).
# Survey admin “Email Sanad offices”: also sends WHATSAPP_TEMPLATE_SURVEY_OFFICE_AR when set (body {{1}} office label, {{2}} survey URL).
# Webhook: GET/POST https://<your-host>/api/webhooks/whatsapp — set verify token in Meta app, same value here.
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLOUD_GRAPH_VERSION=v21.0
# WHATSAPP_TEMPLATE_LANGUAGE_CODE=ar
WHATSAPP_TEMPLATE_SANAD_INVITE_AR=
WHATSAPP_TEMPLATE_SURVEY_OFFICE_AR=
# Attendance alerts — WhatsApp phone to notify when an employee is late or absent.
# Uses templates WHATSAPP_TEMPLATE_ATTENDANCE_LATE_AR and WHATSAPP_TEMPLATE_ATTENDANCE_ABSENT_AR.
# Body params: {{1}} employee name, {{2}} site name, {{3}} minutes late / shift name.
ATTENDANCE_ALERT_MANAGER_PHONE=
WHATSAPP_TEMPLATE_ATTENDANCE_LATE_AR=
WHATSAPP_TEMPLATE_ATTENDANCE_ABSENT_AR=
# Collections reminder — body {{1}} company name, {{2}} invoice ref, {{3}} amount (OMR). Approve template in Meta Business Suite.
# WHATSAPP_TEMPLATE_COLLECTION_REMINDER=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_CLOUD_APP_SECRET=   # if set, POST webhook requires valid X-Hub-Signature-256
